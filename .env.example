# MARROW — local environment template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and must
# NEVER be committed; this `.env.example` (placeholders only) is the committed
# reference. Anything in `.env` is loaded automatically by the demos.

# --- Cortex A/B (`npm run cortex:ab`) — live LLM calls ---
# Without these the A/B demo prints what to set and makes no call.

# Anthropic API key — https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# OpenAI model id (required — must support structured outputs).
# Cheap, well-supported default for the chat.completions structured-output path:
MARROW_CORTEX_OPENAI_MODEL=gpt-4o-mini

# Anthropic model id (optional — defaults to claude-haiku-4-5).
# MARROW_CORTEX_ANTHROPIC_MODEL=claude-haiku-4-5

# --- PostgreSQL (optional — the Mark's persistent adapter) ---
# Set to run the Postgres-backed tests/tour and the MCP server with persistence.
# Bring a DB up with `npm run db:up`, then:
# MARROW_TEST_DATABASE_URL=postgres://postgres:marrow@localhost:55432/marrow
# MARROW_DATABASE_URL=postgres://postgres:marrow@localhost:55432/marrow
